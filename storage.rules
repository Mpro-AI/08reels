rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ========== Helper Functions ==========
    function isSignedIn() {
      return request.auth != null;
    }

    // ========== Main Rule for Videos ==========
    // Allow any signed-in user to read and write anything inside the /videos folder.
    // This is a broad rule for debugging and ensuring functionality.
    // It covers main thumbnails, version thumbnails, video files, and annotations.
    match /videos/{videoId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}

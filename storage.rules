rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // 允許所有已登入用戶讀寫 videos 目錄
    match /videos/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    // 其他路徑拒絕
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

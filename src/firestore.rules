rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helpers ==========
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isCommentAuthor(comment) {
      return isOwner(comment.author.id);
    }
    
    // Check if the only modification to a video document is adding or removing a comment
    function isModifyingComments(request, resource) {
      let isChangingVersions = request.resource.data.diff(resource.data).affectedKeys().hasOnly(['versions']);
      if (!isChangingVersions) {
        return false;
      }

      // Check that other top-level fields are unchanged
      let otherFieldsUnchanged = request.resource.data.title == resource.data.title &&
                                 request.resource.data.author.id == resource.data.author.id &&
                                 request.resource.data.thumbnailUrl == resource.data.thumbnailUrl &&
                                 request.resource.data.thumbnailHint == resource.data.thumbnailHint &&
                                 request.resource.data.uploadedAt == resource.data.uploadedAt;
      if (!otherFieldsUnchanged) {
        return false;
      }
      
      // Now, deeply check versions to ensure only comments changed
      let oldVersions = resource.data.versions;
      let newVersions = request.resource.data.versions;
      
      // Must have same number of versions
      if (oldVersions.size() != newVersions.size()) {
        return false;
      }
      
      // Iterate through versions and check that only comments are different
      let versionIndices = toInt(oldVersions.size()).sequence();
      return versionIndices.all(i => 
        (oldVersions[i].id == newVersions[i].id) &&
        (oldVersions[i].versionNumber == newVersions[i].versionNumber) &&
        (oldVersions[i].status == newVersions[i].status) &&
        (oldVersions[i].uploader.id == newVersions[i].uploader.id) &&
        (oldVersions[i].isCurrentActive == newVersions[i].isCurrentActive) &&
        (oldVersions[i].videoUrl == newVersions[i].videoUrl) &&
        (oldVersions[i].notes == newVersions[i].notes) &&
        // comments can be different
        (oldVersions[i].annotations.size() == newVersions[i].annotations.size())
      );
    }

    // ========== Collections ==========

    // Users can read other user profiles (for assign-to dropdown)
    // and can only write to their own user profile document.
    match /users/{userId} {
      allow read: if isAdmin() || isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    // Videos can be listed and read by any signed-in user.
    // Creation is allowed if the author is the current user.
    // Updates are allowed only by the video's author or admin.
    match /videos/{videoId} {
      allow get, list: if isAdmin() || isSignedIn();
      
      allow create: if isAdmin() || (isSignedIn()
                    && request.resource.data.author.id == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.thumbnailUrl is string
                    && 'uploadedAt' in request.resource.data);

      // Allow updates if the user is an admin, the author of the video,
      // or if any signed-in user is just adding/deleting a comment.
      allow update: if isAdmin() || 
                     isOwner(resource.data.author.id) ||
                     (isSignedIn() && isModifyingComments(request, resource));
      
      allow delete: if isAdmin() || isOwner(resource.data.author.id);
    }
  }
}

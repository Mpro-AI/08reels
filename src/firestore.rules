rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helpers ==========
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Check if user has access to a specific video
    function hasVideoAccess(videoData) {
      // Admins have access to everything
      if (isAdmin()) {
        return true;
      }
      // The author of the video always has access
      if (isOwner(videoData.author.id)) {
        return true;
      }
      // If assignedUserIds is not present or is empty, it's a public video
      if (!('assignedUserIds' in videoData) || videoData.assignedUserIds.size() == 0) {
        return true;
      }
      // If the user's ID is in the assignedUserIds list
      return request.auth.uid in videoData.assignedUserIds;
    }

    // Check if the only modification to a video document is adding or removing a comment/annotation
    function isModifyingOnlySubcollections(request, resource) {
      let isChangingVersions = request.resource.data.diff(resource.data).affectedKeys().hasOnly(['versions']);
      if (!isChangingVersions) {
        return false;
      }

      // Check that other top-level fields are unchanged
      let otherFieldsUnchanged = request.resource.data.title == resource.data.title &&
                                 request.resource.data.author.id == resource.data.author.id &&
                                 request.resource.data.thumbnailUrl == resource.data.thumbnailUrl &&
                                 request.resource.data.thumbnailHint == resource.data.thumbnailHint &&
                                 request.resource.data.uploadedAt == resource.data.uploadedAt &&
                                 request.resource.data.assignedUserIds == resource.data.assignedUserIds &&
                                 request.resource.data.isDeleted == resource.data.isDeleted;

      if (!otherFieldsUnchanged) {
        return false;
      }
      
      // Now, deeply check versions to ensure only comments or annotations changed
      let oldVersions = resource.data.versions;
      let newVersions = request.resource.data.versions;
      
      if (oldVersions.size() != newVersions.size()) {
        return false;
      }
      
      let versionIndices = toInt(oldVersions.size()).sequence();
      return versionIndices.all(i => 
        (oldVersions[i].id == newVersions[i].id) &&
        (oldVersions[i].versionNumber == newVersions[i].versionNumber) &&
        (oldVersions[i].status == newVersions[i].status) &&
        (oldVersions[i].uploader.id == newVersions[i].uploader.id) &&
        (oldVersions[i].isCurrentActive == newVersions[i].isCurrentActive) &&
        (oldVersions[i].videoUrl == newVersions[i].videoUrl) &&
        (oldVersions[i].notes == newVersions[i].notes)
      );
    }

    // ========== Collections ==========

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOwner(userId);
    }

    match /videos/{videoId} {
      // `list` is tricky. We allow any signed-in user to list, but the client-side
      // query must enforce the actual filtering. The `get` rule provides the real security.
      allow list: if isSignedIn();

      allow get: if isSignedIn() && hasVideoAccess(resource.data);
      
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.author.id == request.auth.uid);

      allow update: if isAdmin() || isOwner(resource.data.author.id) || 
                     (isSignedIn() && hasVideoAccess(resource.data) && isModifyingOnlySubcollections(request, resource));
      
      allow delete: if isAdmin() || isOwner(resource.data.author.id);
    }
  }
}
